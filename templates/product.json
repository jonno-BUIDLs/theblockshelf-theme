{
  "sections": {
    "main-product": {
      "type": "main-product",
      "blocks": {
        "vendor": {
          "type": "text",
          "disabled": true,
          "settings": {
            "icon": "none",
            "icon_width": 20,
            "text": "{{ product.vendor }}",
            "text_size": "text-base"
          }
        },
        "title": {
          "type": "title",
          "settings": {
            "title_size": "product-title-md",
            "title_size_mobile": "product-title-md",
            "show_price": true,
            "show_rating": false
          }
        },
        "description_teaser": {
          "type": "description",
          "settings": {
            "text_size": "text-base"
          }
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "show_variant_labels": true,
            "picker_type": "button",
            "enable_color_swatches": true,
            "color_swatch_type": "color",
            "size_chart": ""
          }
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_quantity_selector": true,
            "show_price": false,
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": false,
            "enable_back_in_stock": false,
            "show_back_in_stock_name": false,
            "show_back_in_stock_phone": false
          }
        },
        "reassurance": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{% render 'blockshelf-reassurance' %}"
          }
        },
        "pickup_availability": {
          "type": "pickup_availability",
          "settings": {}
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Share",
            "show_help_desk": true,
            "help_label": "Need help?",
            "help_type": "drawer",
            "help_page": ""
          }
        },
        "sticky_buy_button": {
          "type": "sticky_buy_button",
          "disabled": true,
          "settings": {}
        }
      },
      "block_order": [
        "vendor",
        "title",
        "description_teaser",
        "variant_picker",
        "buy_buttons",
        "reassurance",
        "pickup_availability",
        "share",
        "sticky_buy_button"
      ],
      "settings": {
        "enable_sticky_info": true,
        "media_size": 60,
        "gallery_layout": "thumbnail",
        "thumbnail_position": "beside",
        "image_ratio": "adapt_first",
        "image_zoom": "lightbox",
        "hide_variants": false,
        "enable_video_autoplay": true,
        "enable_video_looping": true,
        "mobile_layout": "full_width",
        "image_ratio_mobile": "adapt_first",
        "mobile_thumbnail": false,
        "padding_top": 24,
        "padding_bottom": 60,
        "divider": false,
        "full_width": true,
        "rounded": false
      }
    },
    "help-drawer": {
      "type": "help-drawer",
      "blocks": {
        "content-1": {
          "type": "content",
          "settings": {
            "icon": "rocket",
            "heading": "Shipping Information",
            "text": "<p>Products are printed on demand, just for you, the moment you order. Like the Bitcoin blockchain—decentralized and trustless. Your goodies may arrive separately and take a few extra block confirmations to reach your doorstep. Estimated delivery: 5–10 business days after your order is placed.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle",
            "color_text": "#b45309",
            "color_background": "#fffbeb",
            "gradient_background": "",
            "color_highlight": "#ffddbf",
            "gradient_highlight": ""
          }
        },
        "content-2": {
          "type": "content",
          "settings": {
            "icon": "headphone",
            "heading": "Customer Support",
            "text": "<p>Need help with your order? We've got you. Reach out at info@theblockshelf.com and we'll get back to you within 24 hours on weekdays.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle",
            "color_text": "#0369a1",
            "color_background": "#f0f9ff",
            "gradient_background": "",
            "color_highlight": "#ffddbf",
            "gradient_highlight": ""
          }
        }
      },
      "block_order": ["content-1", "content-2"],
      "settings": {
        "heading": "Need help?",
        "description": "<p>If you have any questions, you are always welcome to contact us. We'll get back to you as soon as possible, within 24 hours on weekdays.</p>"
      }
    },
    "product-details": {
      "type": "product-details",
      "blocks": {
        "collapsible_tab-1": {
          "type": "collapsible_tab",
          "settings": {
            "icon": "none",
            "heading": "Full description",
            "content": "<p>Full product description goes here — uses the product's default description when left blank.</p>",
            "metafields": ""
          }
        },
        "collapsible_tab-2": {
          "type": "collapsible_tab",
          "settings": {
            "icon": "none",
            "heading": "Materials & care",
            "content": "<p>Premium materials, minted on demand. Spot clean with a damp cloth. Do not machine wash. Bitcoin-proof but not waterproof.</p>",
            "metafields": ""
          }
        },
        "collapsible_tab-3": {
          "type": "collapsible_tab",
          "settings": {
            "icon": "none",
            "heading": "Size guide",
            "content": "<p>Unisex sizing based on US men's. True to size — size up half a size if between sizes.</p>",
            "metafields": ""
          }
        },
        "collapsible_tab-4": {
          "type": "collapsible_tab",
          "settings": {
            "icon": "none",
            "heading": "Shipping & returns",
            "content": "<p>Minted on demand — prints ship in 3–5 business days from our Sydney studio. Free AU shipping over AU$200. 30-day returns on unworn items.</p>",
            "metafields": ""
          }
        }
      },
      "block_order": [
        "collapsible_tab-1",
        "collapsible_tab-2",
        "collapsible_tab-3",
        "collapsible_tab-4"
      ],
      "settings": {
        "style": "with-border",
        "open_first_row": true,
        "specifications_heading": "",
        "heading": "Details",
        "heading_size": "title-md",
        "heading_alignment": "text-left md:items-end md:flex-row",
        "heading_tag": "h2",
        "subheading": "",
        "description": "",
        "button_label": "",
        "button_link": "",
        "button_external": false,
        "button_icon": true,
        "highlighted_text": "none",
        "highlighted_scribble": "circle",
        "color_text": "#fafafa",
        "color_background": "#000000",
        "gradient_background": "",
        "color_highlight": "",
        "gradient_highlight": "",
        "color_button_text": "",
        "color_button_background": "",
        "color_button_gradient": "",
        "padding_top": 40,
        "padding_bottom": 40,
        "divider": false,
        "full_width": false,
        "rounded": false
      }
    },
    "blockshelf-book-promo": {
      "type": "blockshelf-book-promo",
      "settings": {
        "book_handle": "bitcoin-minors",
        "eyebrow": "Pairs with",
        "heading_pre": "Bitcoin",
        "heading_accent": "Minors",
        "body": "<p>The book that started it all. A kids' intro to Bitcoin that slaps. Buy it alongside your order and save 15% on the bundle.</p>",
        "cta_label": "Shop the book",
        "padding_top": 56,
        "padding_bottom": 56
      }
    },
    "blockshelf-mini-faq": {
      "type": "blockshelf-mini-faq",
      "settings": {
        "padding_top": 40,
        "padding_bottom": 56
      }
    },
    "recently-viewed": {
      "type": "recently-viewed",
      "settings": {
        "product_limit": 6,
        "columns": 4,
        "carousel_on_desktop": true,
        "columns_mobile": "1",
        "swipe_on_mobile": true,
        "heading": "You may also like",
        "heading_size": "title-md",
        "heading_alignment": "text-left md:items-end md:flex-row",
        "heading_tag": "h2",
        "subheading": "",
        "description": "",
        "highlighted_text": "none",
        "highlighted_scribble": "circle",
        "color_text": "#fafafa",
        "color_background": "#000000",
        "gradient_background": "",
        "color_highlight": "",
        "gradient_highlight": "",
        "color_button_text": "",
        "color_button_background": "",
        "color_button_gradient": "",
        "padding_top": 40,
        "padding_bottom": 72,
        "divider": false,
        "full_width": false,
        "rounded": false
      }
    }
  },
  "order": [
    "main-product",
    "help-drawer",
    "product-details",
    "blockshelf-book-promo",
    "blockshelf-mini-faq",
    "recently-viewed"
  ]
}
