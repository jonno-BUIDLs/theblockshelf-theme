{%- comment -%}
  THE BLOCKSHELF — Cart drawer (bottom sheet, Variant B)
  ------------------------------------------------------
  REPLACES Harmony's `sections/cart-drawer.liquid`. Slides up from the
  bottom on desktop + mobile; splits into two panes (line-items left,
  subtotal + CTAs right) on desktop, stacks on mobile. Auto-opens for 2s
  on add-to-cart, then auto-closes unless the user is interacting.

  Line items are stripped: thumb · title · variant · price (with sale
  lockup) · remove. Quantity editing lives on the /cart page.

  External contract:
  - Root element: <cart-drawer data-bs-cart-drawer> — expected by
    theme.js's global cart handlers (they dispatch 'cart:open',
    'cart:refresh' events here).
  - Liquid section ID 'cart-drawer' — Harmony's fetch-cart endpoint
    returns this section's rendered HTML on /cart/add.js + .update.js.
{%- endcomment -%}

<cart-drawer
  id="cart-drawer"
  data-bs-cart-drawer
  data-auto-close-ms="{{ section.settings.auto_close_ms | default: 2000 }}"
  class="bs-cart-drawer"
  aria-hidden="true"
  role="dialog"
  aria-labelledby="bs-cart-drawer-title"
  aria-modal="true"
>
  <div class="bs-cart-drawer__scrim" data-bs-cart-close tabindex="-1" aria-hidden="true"></div>

  <aside class="bs-cart-drawer__sheet" role="document">
    <div class="bs-cart-drawer__handle" aria-hidden="true"></div>

    {%- if cart.item_count > 0 -%}
      <div class="bs-cart-drawer__grid">
        {%- comment -%}---------- LEFT PANE — line items ----------{%- endcomment -%}
        <section class="bs-cart-drawer__lines-pane">
          <header class="bs-cart-drawer__head">
            <h2 class="bs-cart-drawer__title" id="bs-cart-drawer-title">
              Your cart
              <span class="bs-cart-drawer__count">
                · {{ cart.item_count }} {% if cart.item_count == 1 %}item{% else %}items{% endif %}
                · {{ cart.total_price | money }} subtotal
              </span>
            </h2>
            <button
              type="button"
              class="bs-cart-drawer__close"
              data-bs-cart-close
              aria-label="Close cart"
            >×</button>
          </header>

          <form action="{{ routes.cart_url }}" method="post" id="bs-cart-drawer-form" class="bs-cart-drawer__form">
            <ul class="bs-cart-drawer__lines" role="list">
              {%- for item in cart.items -%}
                {%- render 'blockshelf-cart-line', item: item, context: 'drawer' -%}
              {%- endfor -%}
            </ul>
          </form>
        </section>

        {%- comment -%}---------- RIGHT PANE — subtotal + CTAs ----------{%- endcomment -%}
        <aside class="bs-cart-drawer__foot-pane">
          <div class="bs-cart-drawer__subtotal">
            <div class="bs-cart-drawer__sub-label">Subtotal</div>
            <div class="bs-cart-drawer__sub-amount" data-bs-subtotal>
              {{ cart.total_price | money }}
            </div>
            <p class="bs-cart-drawer__sub-note">
              Shipping &amp; taxes<br>calculated at checkout
            </p>
          </div>

          <div class="bs-cart-drawer__ctas">
            <button
              type="submit"
              name="checkout"
              form="bs-cart-drawer-form"
              class="bs-cart-drawer__checkout"
            >
              Checkout
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
              </svg>
            </button>
            <a href="{{ routes.cart_url }}" class="bs-cart-drawer__view-cart">
              View full cart →
            </a>
          </div>
        </aside>
      </div>

    {%- else -%}
      {%- comment -%}---------- Empty state (drawer variant) ----------{%- endcomment -%}
      <div class="bs-cart-drawer__empty">
        <header class="bs-cart-drawer__head">
          <h2 class="bs-cart-drawer__title" id="bs-cart-drawer-title">Your cart</h2>
          <button
            type="button"
            class="bs-cart-drawer__close"
            data-bs-cart-close
            aria-label="Close cart"
          >×</button>
        </header>
        {%- render 'blockshelf-empty-cart', context: 'drawer' -%}
      </div>
    {%- endif -%}
  </aside>
</cart-drawer>

{% schema %}
{
  "name": "Cart drawer",
  "tag": "section",
  "class": "shopify-section--cart-drawer",
  "settings": [
    {
      "type": "header",
      "content": "Blockshelf bottom-sheet"
    },
    {
      "type": "paragraph",
      "content": "Auto-opens on add-to-cart, auto-closes after a short hold unless the user hovers or clicks. Layout: two-pane bottom sheet on desktop, stacked on mobile."
    },
    {
      "type": "range",
      "id": "auto_close_ms",
      "label": "Auto-close delay (ms)",
      "min": 1000,
      "max": 5000,
      "step": 250,
      "default": 2000,
      "info": "How long the drawer stays open after add-to-cart before auto-closing. Hovering resets the timer."
    },
  ]
}
{% endschema %}
