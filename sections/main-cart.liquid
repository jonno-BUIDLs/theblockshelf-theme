{%- comment -%}
  THE BLOCKSHELF — Main cart page (editorial layout)
  ---------------------------------------------------
  REPLACES Harmony's `sections/main-cart.liquid`. Editorial card layout
  for the /cart page: large product thumbs, generous whitespace, feels
  like a wishlist review rather than a spreadsheet. Qty steppers live
  here (not in the drawer).

  Composition:
    [eyebrow] ITEMS · N
    [giant headline] "Your stack." / "Nothing stacked." (empty)
    [summary rail] subtotal + free-shipping progress + checkout CTA
    [line items] editorial cards (thumb 1/3, details 2/3, price + qty + remove on the right)
{%- endcomment -%}

<section class="bs-cart-page" data-bs-cart-page>
  <div class="bs-cart-page__inner">

    {%- if cart.item_count > 0 -%}
      <header class="bs-cart-page__head">
        <div class="bs-cart-page__eyebrow">
          <span class="bs-cart-page__dot" aria-hidden="true"></span>
          Cart · {{ cart.item_count }} {% if cart.item_count == 1 %}item{% else %}items{% endif %}
        </div>
        <h1 class="bs-cart-page__heading">
          Your <em>stack.</em>
        </h1>
        <p class="bs-cart-page__sub">
          Review below. All items are minted on demand — check quantity, variant and size now; edits lock in at checkout.
        </p>
      </header>

      <form action="{{ routes.cart_url }}" method="post" id="bs-cart-page-form" class="bs-cart-page__form" novalidate>

        {%- comment -%}
          DOM order: lines first, rail second — rail sits in right column
          via grid-column, lines take column 1. This also gives the
          correct screen-reader reading order on mobile (items, then
          summary) when the rail drops below.
        {%- endcomment -%}

        <ul class="bs-cart-page__lines" role="list">
          {%- for item in cart.items -%}
            {%- render 'blockshelf-cart-line', item: item, context: 'page' -%}
          {%- endfor -%}
        </ul>

        {%- liquid
          assign book_handle  = 'bitcoin-minors-and-degen-descendants'
          assign shoes_handle = 'shoetoshi-nakamotoes'
          assign book_in_cart  = false
          assign shoes_in_cart = false
          for item in cart.items
            if item.product.handle == book_handle
              assign book_in_cart = true
            endif
            if item.product.handle == shoes_handle
              assign shoes_in_cart = true
            endif
          endfor

          assign upsell_product = nil
          unless book_in_cart and shoes_in_cart
            if book_in_cart
              assign upsell_product = all_products[shoes_handle]
            else
              assign upsell_product = all_products[book_handle]
            endif
          endunless
        -%}

        {%- if upsell_product != blank -%}
          {%- assign upsell_variant = upsell_product.first_available_variant -%}
          {%- if upsell_variant -%}
            <div class="bs-cart-page__upsell" data-bs-upsell>
              <p class="bs-cart-page__upsell-eyebrow">Pair it with</p>
              <a href="{{ upsell_product.url }}" class="bs-cart-page__upsell-thumb" tabindex="-1" aria-hidden="true">
                {%- if upsell_product.featured_media -%}
                  {{ upsell_product.featured_media | image_url: width: 300 | image_tag:
                    loading: 'lazy',
                    widths: '120, 240, 300',
                    sizes: '(min-width: 900px) 120px, 80px',
                    alt: upsell_product.title | escape }}
                {%- endif -%}
              </a>
              <div class="bs-cart-page__upsell-info">
                <h3 class="bs-cart-page__upsell-title">{{ upsell_product.title }}</h3>
                <p class="bs-cart-page__upsell-reason">
                  {%- if book_in_cart -%}
                    You've stacked the book. Now kit out the feet. The kids in <em>Bitcoin Minors</em> all wear them.
                  {%- else -%}
                    The book that started it all. A Bitcoin kids book that actually slaps — perfect for the whole fam.
                  {%- endif -%}
                </p>
                <p class="bs-cart-page__upsell-price">
                  {%- if upsell_variant.compare_at_price > upsell_variant.price -%}
                    <s>{{ upsell_variant.compare_at_price | money }}</s>&thinsp;{{ upsell_variant.price | money }} · <span style="color:var(--bs-primary)">On Sale</span>
                  {%- else -%}
                    {{ upsell_variant.price | money }}
                  {%- endif -%}
                </p>
              </div>
              <button
                type="button"
                class="bs-cart-page__upsell-add"
                data-bs-upsell-add
                data-variant-id="{{ upsell_variant.id }}"
                aria-label="Add {{ upsell_product.title | escape }} to cart"
              >
                Add to stack
                <svg width="12" height="12" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
                </svg>
              </button>
            </div>
          {%- endif -%}
        {%- endif -%}

        <aside class="bs-cart-page__rail" data-bs-cart-rail>
          <div class="bs-cart-page__rail-inner">
            <div class="bs-cart-page__rail-row">
              <span class="bs-cart-page__rail-label">Subtotal</span>
              <span class="bs-cart-page__rail-amount" data-bs-subtotal>{{ cart.total_price | money }}</span>
            </div>

            <p class="bs-cart-page__rail-note">
              Shipping &amp; taxes calculated at checkout. Minted on demand · ships in 3 days · Sydney, AU.
            </p>

            <button type="submit" name="checkout" class="bs-cart-page__checkout">
              Checkout
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
              </svg>
            </button>

            {%- if additional_checkout_buttons -%}
              <div class="bs-cart-page__express">{{ content_for_additional_checkout_buttons }}</div>
            {%- endif -%}

            <div class="bs-cart-page__reassure">
              <div><span>Minted on</span><strong>Demand</strong></div>
              <div><span>Ships in</span><strong>3 days</strong></div>
              <div><span>Studio</span><strong>Sydney, AU</strong></div>
            </div>
          </div>
        </aside>

        {%- if cart.cart_level_discount_applications.size > 0 -%}
          <div class="bs-cart-page__discounts">
            {%- for discount in cart.cart_level_discount_applications -%}
              <span class="bs-cart-page__discount">
                {{ discount.title }} · −{{ discount.total_allocated_amount | money }}
              </span>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.show_note -%}
          <details class="bs-cart-page__note">
            <summary>Add a note to your order</summary>
            <textarea name="note" class="bs-cart-page__note-input" rows="3" placeholder="Anything we should know?">{{ cart.note }}</textarea>
          </details>
        {%- endif -%}
      </form>

    {%- else -%}
      {%- render 'blockshelf-empty-cart', context: 'page' -%}
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Cart page",
  "tag": "section",
  "class": "shopify-section--main-cart",
  "settings": [
    {
      "type": "header",
      "content": "Blockshelf editorial cart"
    },
    {
      "type": "checkbox",
      "id": "show_note",
      "label": "Show order-note field",
      "default": true
    }
  ]
}
{% endschema %}
